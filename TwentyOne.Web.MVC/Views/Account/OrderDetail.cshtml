@model TwentyOne.Shared.DTOs.Responses.OrderResponseDto
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Order Detail";
}

<div class="container py-5">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Account/MyOrders" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h5 class="mb-0 fw-bold">Order @Model.OrderNumber</h5>
            <p class="text-muted mb-0" style="font-size:13px">
                Placed on @Model.CreatedAt.ToString("MMM dd, yyyy")
            </p>
        </div>
        <span class="ms-auto badge badge-@Model.Status.ToLower() fs-6">
            @Model.Status
        </span>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius:12px">
                <div class="card-header bg-white fw-bold">Order Items</div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Price</th>
                                <th>Qty</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4">@item.ProductName</td>
                                    <td>৳@item.UnitPrice.ToString("N0")</td>
                                    <td>@item.Quantity</td>
                                    <td>
                                        <strong>
                                            ৳@item.Subtotal.ToString("N0")
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span>৳@Model.FinalAmount.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Customer Card -->
            <div class="card border-0 shadow-sm mb-3"
                 style="border-radius:12px">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-person me-2"></i>Customer
                    </h6>
                    <div class="fw-semibold">
                        @Model.CustomerName
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                    {
                        <div class="text-muted mt-1"
                             style="font-size:13px">
                            <i class="bi bi-telephone me-2"></i>
                            @Model.CustomerPhone
                        </div>
                    }
                    @* Only show email if it's a real customer email *@
                    @if (!string.IsNullOrEmpty(Model.CustomerEmail) &&
                         Model.CustomerEmail != "guest@twentyone.com")
                    {
                        <div class="text-muted mt-1"
                             style="font-size:13px">
                            <i class="bi bi-envelope me-2"></i>
                            @Model.CustomerEmail
                        </div>
                    }
                </div>
            </div>
            <!-- Delivery Address Card -->
            <div class="card border-0 shadow-sm mb-3"
                 style="border-radius:12px">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-geo-alt me-2"></i>
                        Delivery Address
                    </h6>
                    <p class="mb-0" style="font-size:14px">
                        @Model.DeliveryAddress
                    </p>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr />
                        <p class="mb-0 text-muted"
                           style="font-size:13px">
                            <i class="bi bi-chat-left-text me-1">
                            </i>
                            @Model.Notes
                        </p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3" style="border-radius:12px">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Delivery Address</h6>
                    <p class="text-muted mb-0" style="font-size:14px">
                        @Model.DeliveryAddress
                    </p>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr />
                        <p class="text-muted mb-0" style="font-size:13px">
                            <strong>Notes:</strong> @Model.Notes
                        </p>
                    }
                </div>
                <a href="/Account/DownloadOrderPdf/@Model.Id"
                   class="btn btn-outline-primary btn-sm"
                   target="_blank">
                    <i class="bi bi-file-pdf me-1"></i>
                    Download PDF
                </a>
            </div>
        </div>
    </div>
</div>
