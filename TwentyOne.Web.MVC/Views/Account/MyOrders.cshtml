@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "My Orders";
    var orders = ViewBag.Orders as
        List<TwentyOne.Shared.DTOs.Responses.OrderResponseDto>;
    var preOrders = ViewBag.PreOrders as
        List<TwentyOne.Shared.DTOs.Responses.PreOrderResponseDto>;
    var apiUrl = ApiConfig.PublicBaseUrl;
}

<div class="container py-5">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-receipt me-2"></i>My Orders
    </h4>

    <!-- Regular Orders -->
    <h6 class="fw-bold text-muted mb-3"
        style="text-transform:uppercase;
        letter-spacing:1px;font-size:12px">
        <i class="bi bi-bag me-2"></i>Regular Orders
    </h6>

    @if (orders != null && orders.Any())
    {
        <div class="card border-0 shadow-sm mb-5" style="border-radius:12px">
            <div class="card-body p-0">
                <div class="table-responsive" style="border-radius:12px;">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4" style="white-space: nowrap;">Order </th>
                                <th style="white-space: nowrap;">Items</th>
                                <th style="white-space: nowrap;">Total</th>
                                <th style="white-space: nowrap;">Status</th>
                                <th style="white-space: nowrap;">Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>@order.OrderNumber</strong>
                                    </td>
                                    <td style="font-size:13px; white-space: nowrap;">
                                        @order.Items.Count items
                                    </td>
                                    <td style="white-space: nowrap;">
                                        <strong>
                                            ৳@order.FinalAmount.ToString("N0")
                                        </strong>
                                    </td>
                                    <td>
                                        <span class="badge badge-@order.Status.ToLower()">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td style="font-size:13px; color:#6c757d; white-space: nowrap;">
                                        @order.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a href="/Account/OrderDetail/@order.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-4 mb-5"
             style="background:#f8f9fa;border-radius:12px">
            <i class="bi bi-bag"
               style="font-size:40px;color:#dee2e6"></i>
            <p class="mt-2 text-muted mb-2">No regular orders yet</p>
            <a href="/Home/Shop" class="btn btn-primary btn-sm">
                Start Shopping
            </a>
        </div>
    }

    <!-- Pre-Orders -->
    <h6 class="fw-bold text-muted mb-3"
        style="text-transform:uppercase;
        letter-spacing:1px;font-size:12px">
        <i class="bi bi-clock-history me-2"></i>Pre-Orders
    </h6>

    @if (preOrders != null && preOrders.Any())
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var po in preOrders)
            {
                <div class="card border-0 shadow-sm"
                     style="border-radius:12px">
                    <div class="card-body p-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div style="width:60px;height:60px;
                                    background:#fff0f3;border-radius:8px;
                                    display:flex;align-items:center;
                                    justify-content:center;flex-shrink:0">
                                    <i class="bi bi-car-front"
                                       style="font-size:22px;color:#e94560"></i>
                                </div>
                            </div>
                            <div class="col">
                                <div style="font-size:11px;color:#e94560;
                                    font-weight:600">
                                    @po.PreOrderNumber
                                </div>
                                <div class="fw-bold">@po.ProductName</div>
                                <div class="d-flex gap-3 mt-1"
                                     style="font-size:12px;color:#6c757d">
                                    <span>
                                        Paid:
                                        <strong class="text-success">
                                            ৳@po.DepositAmount.ToString("N0")
                                        </strong>
                                    </span>
                                    <span>
                                        Due:
                                        <strong class="text-danger">
                                            ৳@po.RemainingAmount.ToString("N0")
                                        </strong>
                                    </span>
                                </div>
                            </div>
                            <div class="col-auto text-center">
                                @{
                                    var bc = po.Status switch
                                    {
                                        "Pending" => "warning text-dark",
                                        "Confirmed" => "info text-dark",
                                        "Ready" => "success",
                                        "Delivered" => "primary",
                                        "Cancelled" => "danger",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@bc">@po.Status</span>
                                @if (po.Status == "Ready")
                                {
                                    <div style="font-size:10px;
                                        color:#198754;
                                        font-weight:600;
                                        margin-top:3px">
                                        🎉 Arrived!
                                    </div>
                                }
                            </div>
                            <div class="col-auto">
                                <a href="/Account/PreOrderDetail/@po.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(po.AdminNotes))
                        {
                            <div class="mt-2 p-2"
                                 style="background:#f0f7ff;
                                border-radius:8px;
                                font-size:12px">
                                <i class="bi bi-chat-left-text me-1
                                text-primary"></i>
                                @po.AdminNotes
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-4"
             style="background:#f8f9fa;border-radius:12px">
            <i class="bi bi-clock-history"
               style="font-size:40px;color:#dee2e6"></i>
            <p class="mt-2 text-muted mb-2">No pre-orders yet</p>
            <a href="/Home/Shop?isPreOrder=true"
               class="btn btn-info btn-sm text-dark">
                Browse Pre-Order Products
            </a>
        </div>
    }
</div>