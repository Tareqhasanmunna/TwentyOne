@model List<TwentyOne.Shared.DTOs.Responses.PreOrderResponseDto>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "My Pre-Orders";
    var apiUrl = ApiConfig.PublicBaseUrl;
}

<div class="container py-5">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-clock-history me-2"></i>My Pre-Orders
    </h4>

    @if (Model != null && Model.Any())
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var preOrder in Model)
            {
                <div class="card border-0 shadow-sm"
                     style="border-radius:16px">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-2">
                                @if (!string.IsNullOrEmpty(
                                    preOrder.ProductImageUrl))
                                {
                                    <img src="@(apiUrl +
                                                                                 preOrder.ProductImageUrl)"
                                         style="width:80px;height:80px;
                                    object-fit:cover;
                                    border-radius:10px" />
                                }
                                else
                                {
                                    <div style="width:80px;height:80px;
                                        background:#f8f9fa;
                                        border-radius:10px;
                                        display:flex;
                                        align-items:center;
                                        justify-content:center">
                                        <i class="bi bi-car-front"
                                           style="font-size:30px;
                                        color:#dee2e6"></i>
                                    </div>
                                }
                            </div>

                            <div class="col-md-5">
                                <div style="font-size:11px;color:#e94560;
                                    font-weight:600">
                                    @preOrder.PreOrderNumber
                                </div>
                                <div class="fw-bold mt-1">
                                    @preOrder.ProductName
                                </div>
                                <div class="mt-2 d-flex gap-3"
                                     style="font-size:13px;color:#6c757d">
                                    <span>
                                        Deposit paid:
                                        <strong class="text-success">
                                            ৳@preOrder.DepositAmount
                                            
                                        </strong>
                                    </span>
                                    <span>
                                        Remaining:
                                        <strong class="text-danger">
                                            ৳@preOrder.RemainingAmount
                                        </strong>
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2 text-center">
                                @{
                                    var badgeClass = preOrder.Status switch
                                    {
                                        "Pending" => "warning text-dark",
                                        "Confirmed" => "info text-dark",
                                        "Ready" => "success",
                                        "Delivered" => "primary",
                                        "Cancelled" => "danger",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@badgeClass fs-6">
                                    @preOrder.Status
                                </span>

                                @if (preOrder.Status == "Ready")
                                {
                                    <div class="mt-2"
                                         style="font-size:11px;
                                        color:#198754;
                                        font-weight:600">
                                        🎉 Product arrived!
                                    </div>
                                }
                            </div>

                            <div class="col-md-3 text-end">
                                <a href="/Account/PreOrderDetail/@preOrder.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    View Details
                                </a>

                                @if (preOrder.Status == "Pending")
                                {
                                    <form asp-action="CancelPreOrder"
                                          asp-controller="Account"
                                          method="post" class="mt-2"
                                          onsubmit="return confirm(
                                        'Cancel this pre-order?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id"
                                               value="@preOrder.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm">
                                            Cancel
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(preOrder.AdminNotes))
                        {
                            <div class="mt-3 p-3"
                                 style="background:#f8f9fa;
                                border-radius:8px;
                                font-size:13px">
                                <i class="bi bi-chat-left-text me-2
                                text-primary"></i>
                                <strong>Note from store:</strong>
                                @preOrder.AdminNotes
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-clock-history"
               style="font-size:80px;color:#dee2e6"></i>
            <h5 class="mt-3 text-muted">No pre-orders yet</h5>
            <a href="/Home/Shop?isPreOrder=true"
               class="btn btn-primary mt-3">
                Browse Pre-Order Products
            </a>
        </div>
    }
</div>