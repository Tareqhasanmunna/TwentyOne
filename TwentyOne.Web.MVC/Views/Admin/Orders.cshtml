@model List<TwentyOne.Shared.DTOs.Responses.OrderResponseDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-bold">All Orders</h5>
        <p class="text-muted mb-0" style="font-size:13px">
            Manage customer orders
        </p>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Order #</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <strong>@order.OrderNumber</strong>
                            </td>
                            <td>
                                <div>@order.CustomerName</div>
                                @if (!string.IsNullOrEmpty(order.CustomerPhone))
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-telephone me-1"></i>
                                        @order.CustomerPhone
                                    </small>
                                }
                                else
                                {
                                    <small class="text-muted">
                                        @order.CustomerEmail
                                    </small>
                                }
                            </td>

                            <td>
                                <span class="badge bg-light text-dark border">
                                    @order.Items.Count items
                                </span>
                            </td>
                            <td><strong>৳@order.FinalAmount.ToString("N0")</strong></td>
                            <td>
                                <span class="badge badge-@order.Status.ToLower()">
                                    @order.Status
                                </span>
                            </td>
                            <td style="font-size:13px;color:#6c757d">
                                @order.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <a href="/Admin/OrderDetail/@order.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-receipt"
                               style="font-size:40px;opacity:0.2"></i>
                            <p class="mt-2 mb-0">No orders yet</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
