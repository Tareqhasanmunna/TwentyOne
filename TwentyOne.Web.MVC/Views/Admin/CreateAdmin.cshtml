@model TwentyOne.Shared.DTOs.Requests.CreateAdminDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Admin";
    
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/Admin/Dashboard"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h5 class="mb-0 fw-bold">Create Admin Account</h5>
                <p class="text-muted mb-0" style="font-size:13px">
                    SuperAdmin only — create new admin users
                </p>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger"
                         style="border-radius:10px;font-size:13px">
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState
                                .Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="CreateAdmin"
                      asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Full Name
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FullName"
                               class="form-control"
                               placeholder="Admin full name" />
                        <span asp-validation-for="FullName"
                              class="text-danger"
                              style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Email Address
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="admin@twentyone.com" />
                        <span asp-validation-for="Email"
                              class="text-danger"
                              style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Phone Number
                        </label>
                        <input asp-for="PhoneNumber"
                               class="form-control"
                               placeholder="01700000000" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Password
                            <span class="text-danger">*</span>
                        </label>

                        <div class="input-group">
                            <input asp-for="Password"
                                   id="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Min 8 characters" />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="togglePassword('Password', 'passwordIcon')">
                                <i id="passwordIcon" class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="Password"
                              class="text-danger"
                              style="font-size:12px"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Confirm Password
                            <span class="text-danger">*</span>
                        </label>

                        <div class="input-group">
                            <input asp-for="ConfirmPassword"
                                   id="ConfirmPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Repeat password" />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="togglePassword('ConfirmPassword', 'confirmPasswordIcon')">
                                <i id="confirmPasswordIcon" class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"
                              style="font-size:12px"></span>
                    </div>

                    <!-- Password rules -->
                    <div class="p-3 mb-4"
                         style="background:#f8f9fa;
                        border-radius:10px;
                        font-size:12px;color:#6c757d">
                        <i class="bi bi-shield-check me-2
                        text-success"></i>
                        Password must be at least 8 characters,
                        include uppercase, lowercase and a number.
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        <i class="bi bi-person-plus me-2"></i>
                        Create Admin Account
                    </button>
                </form>
            </div>
        </div>

        <!-- Info card -->
        <div class="card mt-4 border-0"
             style="background:#fff8f0;border-radius:12px">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-2">
                    <i class="bi bi-info-circle me-2
                    text-warning"></i>
                    About Admin Accounts
                </h6>
                <ul style="font-size:13px;color:#6c757d;
                    padding-left:20px;margin:0">
                    <li>
                        Admin accounts can manage products,
                        brands, orders and coupons
                    </li>
                    <li>
                        Admins cannot create other admin accounts
                        — only SuperAdmin can
                    </li>
                    <li>
                        To deactivate an admin, contact the
                        system SuperAdmin
                    </li>
                    <li>
                        Each admin should use a unique email
                        address
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
}