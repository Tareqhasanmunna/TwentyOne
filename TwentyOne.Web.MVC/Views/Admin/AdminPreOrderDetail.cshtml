@model TwentyOne.Shared.DTOs.Responses.PreOrderResponseDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pre-Order Detail";
    var apiUrl = ApiConfig.PublicBaseUrl;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/PreOrders"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h5 class="mb-0 fw-bold">@Model.PreOrderNumber</h5>
        <p class="text-muted mb-0" style="font-size:13px">
            Placed on @Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")
        </p>
    </div>
    @{
        var bc = Model.Status switch
        {
            "Pending" => "badge-pending",
            "Confirmed" => "badge-confirmed",
            "Ready" => "badge-delivered",
            "Delivered" => "badge-shipped",
            "Cancelled" => "badge-cancelled",
            _ => "bg-secondary"
        };
    }
    <span class="ms-auto badge @bc fs-6">@Model.Status</span>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <!-- Product -->
        <div class="card mb-4">
            <div class="card-header fw-bold">Product</div>
            <div class="card-body d-flex gap-3">
                <div style="width:80px;height:80px;
                    background:#fff0f3;border-radius:10px;
                    display:flex;align-items:center;
                    justify-content:center">
                    <i class="bi bi-car-front"
                       style="font-size:30px;color:#e94560"></i>
                </div>
                <div>
                    <div class="fw-bold fs-5">@Model.ProductName</div>
                    <div class="text-muted mt-1">
                        Full Price:
                        <strong>
                            ৳@Model.ProductPrice.ToString("N0")
                        </strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Info -->
        <div class="card mb-4">
            <div class="card-header fw-bold">Payment Details</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3"
                             style="background:#f0fff4;
                            border-radius:10px;
                            border:1px solid #c3e6cb">
                            <div style="font-size:12px;color:#6c757d">
                                Deposit Paid
                            </div>
                            <div style="font-size:24px;font-weight:800;
                                color:#198754">
                                ৳@Model.DepositAmount.ToString("N0")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3"
                             style="background:#fff5f5;
                            border-radius:10px;
                            border:1px solid #f5c6cb">
                            <div style="font-size:12px;color:#6c757d">
                                Remaining Due
                            </div>
                            <div style="font-size:24px;font-weight:800;
                                color:#e94560">
                                ৳@Model.RemainingAmount.ToString("N0")
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3 p-3"
                     style="background:#fff8f0;border-radius:10px">
                    <div class="row">
                        <div class="col-md-6">
                            <div style="font-size:12px;color:#6c757d">
                                bKash Transaction ID
                            </div>
                            <div style="font-size:16px;font-weight:700;
                                letter-spacing:2px;color:#e2136e">
                                @Model.BkashTransactionId
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div style="font-size:12px;color:#6c757d">
                                Sender Number
                            </div>
                            <div style="font-size:16px;font-weight:700">
                                @Model.BkashSenderNumber
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customer Info -->
        <div class="card">
            <div class="card-header fw-bold">Customer</div>
            <div class="card-body">
                <div class="fw-bold">@Model.CustomerName</div>
                <div class="text-muted">@Model.CustomerEmail</div>
                @if (Model.DeadlineDate.HasValue)
                {
                    <div class="mt-2" style="font-size:13px">
                        Pre-order deadline:
                        <strong>
                            @Model.DeadlineDate.Value
                            
                        </strong>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Update Status -->
        @if (Model.Status != "Delivered" &&
             Model.Status != "Cancelled")
        {
            <div class="card mb-4">
                <div class="card-header fw-bold">Update Status</div>
                <div class="card-body">
                    <form asp-action="UpdatePreOrderStatus"
                          asp-controller="Admin" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id"
                               value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                New Status
                            </label>
                            <select name="status" class="form-select">
                                @if (Model.Status == "Pending")
                                {
                                    <option value="1">
                                        Confirmed
                                        (Payment Verified)
                                    </option>
                                    <option value="4">
                                        Cancelled
                                    </option>
                                }
                                @if (Model.Status == "Confirmed")
                                {
                                    <option value="2">
                                        Ready
                                        (Product Arrived)
                                    </option>
                                }
                                @if (Model.Status == "Ready")
                                {
                                    <option value="3">
                                        Delivered
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Note to Customer
                                (optional)
                            </label>
                            <textarea name="adminNotes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="e.g. Payment verified. Expected arrival: June 2025">
                            </textarea>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100">
                            <i class="bi bi-check-lg me-1"></i>
                            Update Status
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Terms Accepted -->
        <div class="card">
            <div class="card-header fw-bold">Terms</div>
            <div class="card-body">
                @if (Model.TermsAccepted)
                {
                    <div class="text-success">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        Customer accepted all terms
                    </div>
                }
                else
                {
                    <div class="text-danger">
                        <i class="bi bi-x-circle-fill me-2"></i>
                        Terms not accepted
                    </div>
                }
            </div>
        </div>
    </div>
</div>