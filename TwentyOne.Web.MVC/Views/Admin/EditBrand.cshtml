@model TwentyOne.Shared.DTOs.Requests.UpdateBrandDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Brand";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/Admin/Brands" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h5 class="mb-0 fw-bold">Edit Brand</h5>
                <p class="text-muted mb-0" style="font-size:13px">
                    Update brand information
                </p>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form asp-action="EditBrand" asp-controller="Admin"
                      asp-route-id="@ViewBag.BrandId" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Brand Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name"
                              class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description"
                                  class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Brand Logo</label>

                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                        {
                            <div class="mb-2">
                                <img src="@("http://localhost:5300" + Model.LogoUrl)"
                                     alt="Current Logo"
                                     style="height:60px;object-fit:contain;border:1px solid #eee;
                                border-radius:8px;padding:5px" />
                                <small class="text-muted ms-2">Current logo</small>
                            </div>
                        }

                        <input type="file" name="logoImage" class="form-control"
                               accept="image/jpeg,image/png,image/webp" />
                        <small class="text-muted">
                            Upload a new image to replace the current logo. Max 2MB.
                        </small>

                        @* Keep existing LogoUrl if no new image uploaded *@
                        <input type="hidden" asp-for="LogoUrl" />
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="IsActive"
                                   class="form-check-input" type="checkbox" />
                            <label class="form-check-label fw-semibold">
                                Active
                            </label>
                        </div>
                        <small class="text-muted">
                            Inactive brands won't appear on the public site
                        </small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                        <a href="/Admin/Brands"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" style="border-radius:10px;font-size:13px">
        <strong>Please fix the following errors:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var error in ViewData.ModelState.Values
                .SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}