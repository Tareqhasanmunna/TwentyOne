@model List<TwentyOne.Shared.DTOs.Responses.PreOrderResponseDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pre-Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-bold">Pre-Orders</h5>
        <p class="text-muted mb-0" style="font-size:13px">
            Manage customer pre-orders
        </p>
    </div>
    <!-- Status filter -->
    <div class="d-flex gap-2">
        <a href="/Admin/PreOrders"
           class="btn btn-sm btn-outline-secondary">All</a>
        <a href="/Admin/PreOrders?status=Pending"
           class="btn btn-sm btn-warning">Pending</a>
        <a href="/Admin/PreOrders?status=Confirmed"
           class="btn btn-sm btn-info">Confirmed</a>
        <a href="/Admin/PreOrders?status=Ready"
           class="btn btn-sm btn-success">Ready</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Pre-Order #</th>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Deposit</th>
                    <th>Remaining</th>
                    <th>bKash TXN</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var po in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <strong style="font-size:12px">
                                    @po.PreOrderNumber
                                </strong>
                            </td>
                            <td>
                                <div style="font-size:13px">
                                    @po.CustomerName
                                </div>
                                <small class="text-muted">
                                    @po.CustomerEmail
                                </small>
                            </td>
                            <td style="font-size:13px;max-width:150px">
                                @po.ProductName
                            </td>
                            <td>
                                <span class="text-success fw-bold">
                                    ৳@po.DepositAmount.ToString("N0")
                                </span>
                            </td>
                            <td>
                                <span class="text-danger fw-bold">
                                    ৳@po.RemainingAmount.ToString("N0")
                                </span>
                            </td>
                            <td>
                                <code style="font-size:11px">
                                    @po.BkashTransactionId
                                </code>
                                <br />
                                <small class="text-muted">
                                    @po.BkashSenderNumber
                                </small>
                            </td>
                            <td>
                                @{
                                    var bc = po.Status switch
                                    {
                                        "Pending" =>
                                            "badge-pending",
                                        "Confirmed" =>
                                            "badge-confirmed",
                                        "Ready" =>
                                            "badge-delivered",
                                        "Delivered" =>
                                            "badge-shipped",
                                        "Cancelled" =>
                                            "badge-cancelled",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @bc">
                                    @po.Status
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6c757d">
                                @po.CreatedAt.ToString("MMM dd")
                            </td>
                            <td>
                                <a href="/Admin/PreOrderDetail/@po.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9"
                            class="text-center text-muted py-5">
                            <i class="bi bi-clock-history"
                               style="font-size:40px;opacity:0.2"></i>
                            <p class="mt-2 mb-0">No pre-orders yet</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>