@model TwentyOne.Shared.DTOs.Requests.CreateBrandDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Brand";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/Admin/Brands" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h5 class="mb-0 fw-bold">Add New Brand</h5>
                <p class="text-muted mb-0" style="font-size:13px">
                    Create a new diecast brand
                </p>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form asp-action="CreateBrand" asp-controller="Admin" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Brand Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="e.g. Hot Wheels" />
                        <span asp-validation-for="Name"
                              class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="3"
                                  placeholder="Brief description of the brand"></textarea>
                        <span asp-validation-for="Description"
                              class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Brand Logo</label>

                        <input type="file" name="logoImage" class="form-control"
                               accept="image/jpeg,image/png,image/webp" />
                        <small class="text-muted">
                            Max 2MB. JPG, PNG, WEBP only.
                        </small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Create Brand
                        </button>
                        <a href="/Admin/Brands"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" style="border-radius:10px;font-size:13px">
        <strong>Please fix the following errors:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var error in ViewData.ModelState.Values
                .SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}
