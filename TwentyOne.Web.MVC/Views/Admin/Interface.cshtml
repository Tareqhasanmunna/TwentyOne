@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Interface";
}

<div class="row g-4">
    <!-- Site Logo -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-image me-2"></i>Site Logo
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(ViewBag.LogoUrl as string))
                {
                    <img src="@("http://localhost:5300" + ViewBag.LogoUrl)"
                         alt="Site Logo"
                         style="height:60px;object-fit:contain;
                    border:1px solid #eee;border-radius:8px;
                    padding:5px" />
                }

                <form asp-action="UploadSiteLogo"
                      asp-controller="Admin"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <input type="file" name="logoFile"
                               class="form-control"
                               accept="image/jpeg,image/png,image/webp" />
                        <small class="text-muted">
                            Recommended: square image, max 2MB
                        </small>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-upload me-1"></i> Upload Logo
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Delivery Charges -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-truck me-2"></i>Delivery Charges
            </div>
            <div class="card-body">
                <form asp-action="UpdateDeliveryCharges"
                      asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Inside Dhaka (৳)
                        </label>
                        <input type="number"
                               name="insideDhaka"
                               class="form-control"
                               value="@ViewBag.InsideDhakaCharge"
                               min="0" />
                        <small class="text-muted">
                            Current: ৳@ViewBag.InsideDhakaCharge
                        </small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Outside Dhaka (৳)
                        </label>
                        <input type="number"
                               name="outsideDhaka"
                               class="form-control"
                               value="@ViewBag.OutsideDhakaCharge"
                               min="0" />
                        <small class="text-muted">
                            Current: ৳@ViewBag.OutsideDhakaCharge
                        </small>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        <i class="bi bi-save me-1"></i>
                        Update Charges
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- bKash Number -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-phone me-2"></i>bKash Number
            </div>
            <div class="card-body">
                <form asp-action="UpdateBkashNumber"
                      asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            bKash Number
                        </label>
                        <input type="text"
                               name="bkashNumber"
                               class="form-control"
                               value="@ViewBag.BkashNumber"
                               placeholder="01XXXXXXXXX" />
                        <small class="text-muted">
                            Customers send pre-order deposits here
                        </small>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        <i class="bi bi-save me-1"></i>
                        Update bKash Number
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Upload Banner -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-image me-2"></i>Add Banner
            </div>
            <div class="card-body">
                <form asp-action="UploadBanner"
                      asp-controller="Admin"
                      method="post"
                      enctype="multipart/form-data"
                      id="bannerForm">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Banner Image <span class="text-danger">*</span>
                        </label>
                        <input type="file" name="bannerImage"
                               id="bannerImageInput"
                               class="form-control" required
                               accept="image/jpeg,image/png,image/webp"
                               onchange="previewBanner(this)" />
                        <small class="text-muted">
                            Recommended: 1920x500px. Max 5MB.
                        </small>
                    </div>

                    <!-- Preview Box -->
                    <div id="previewBox"
                         style="display:none;margin-bottom:15px">
                        <label class="form-label fw-semibold">Preview</label>
                        <div style="width:100%;height:180px;
                            overflow:hidden;border-radius:8px;
                            border:2px solid #e94560;
                            position:relative;background:#000">
                            <img id="previewImg"
                                 style="width:100%;height:100%;
                            object-fit:cover;
                            cursor:move;
                            transition:object-position 0.2s"
                                 src="" alt="Preview" />
                        </div>

                        <!-- Position controls -->
                        <div class="mt-2">
                            <label class="form-label"
                                   style="font-size:12px;color:#6c757d">
                                Adjust vertical position
                            </label>
                            <input type="range" class="form-range"
                                   id="positionSlider"
                                   min="0" max="100" value="50"
                                   oninput="adjustPosition(this.value)" />
                            <div class="d-flex justify-content-between"
                                 style="font-size:11px;color:#aaa">
                                <span>Top</span>
                                <span>Center</span>
                                <span>Bottom</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Title</label>
                        <input type="text" name="title"
                               class="form-control"
                               placeholder="Optional banner title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Subtitle</label>
                        <input type="text" name="subtitle"
                               class="form-control"
                               placeholder="Optional subtitle" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Display Order
                        </label>
                        <input type="number" name="displayOrder"
                               class="form-control" value="0" />
                        <small class="text-muted">
                            Lower number = shown first
                        </small>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload me-1"></i> Upload Banner
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Banner List -->
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-images me-2"></i>
                Banners (@(((List<TwentyOne.Shared.DTOs.Responses.BannerResponseDto>)ViewBag.Banners).Count)/5)
            </div>
            <div class="card-body">
                @{
                    var banners = ViewBag.Banners as
                        List<TwentyOne.Shared.DTOs.Responses.BannerResponseDto>;
                }
                @if (banners != null && banners.Any())
                {
                    <div class="row g-3">
                        @foreach (var banner in banners)
                        {
                            <div class="col-md-4">
                                <div class="card border">
                                    <img src="@("http://localhost:5300" + banner.ImageUrl)"
                                         style="height:150px;object-fit:cover;
                                    border-radius:8px 8px 0 0" />
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between
                                            align-items-center">
                                            <div>
                                                <div class="fw-semibold"
                                                     style="font-size:13px">
                                                    @(banner.Title ?? "No title")
                                                </div>
                                                <div class="text-muted"
                                                     style="font-size:11px">
                                                    Order: @banner.DisplayOrder
                                                </div>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <form asp-action="ToggleBanner"
                                                      asp-controller="Admin"
                                                      method="post"
                                                      style="display:inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden"
                                                           name="id"
                                                           value="@banner.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm @(banner.IsActive ? "btn-success" : "btn-secondary")">
                                                        <i class="bi bi-toggle-@(banner.IsActive ? "on" : "off")"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="DeleteBanner"
                                                      asp-controller="Admin"
                                                      method="post"
                                                      style="display:inline"
                                                      onsubmit="return confirm('Delete banner?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden"
                                                           name="id"
                                                           value="@banner.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">
                        No banners uploaded yet
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewBanner(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('previewBox').style.display = 'block';
                    document.getElementById('positionSlider').value = 50;
                    adjustPosition(50);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function adjustPosition(value) {
            document.getElementById('previewImg').style.objectPosition =
                'center ' + value + '%';
        }
    </script>
}