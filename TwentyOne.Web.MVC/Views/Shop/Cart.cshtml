@model List<TwentyOne.Web.MVC.Controllers.CartItemViewModel>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Cart";
    decimal total = Model?.Sum(i => i.Subtotal) ?? 0;
    var apiUrl = ApiConfig.PublicBaseUrl;
}

<div class="container py-5">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-cart3 me-2"></i>Shopping Cart
    </h4>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm" style="border-radius:12px">
                    <div class="card-body p-0">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-3 p-4 border-bottom position-relative w-100">

                                <div class="d-flex align-items-center gap-3 flex-grow-1 w-100">
                                    <div style="width:70px; height:70px; background:#f8f9fa; border-radius:8px; overflow:hidden; flex-shrink:0;">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@(apiUrl + item.ImageUrl)" style="width:100%; height:100%; object-fit:cover" />
                                        }
                                        else
                                        {
                                            <div style="height:100%; display:flex; align-items:center; justify-content:center">
                                                <i class="bi bi-car-front" style="color:#dee2e6; font-size:24px;"></i>
                                            </div>
                                        }
                                    </div>

                                    <div style="flex-grow:1">
                                        <div class="fw-semibold">@item.ProductName</div>
                                        @if (item.HasDiscount)
                                        {
                                            <div style="font-size:12px">
                                                <span class="text-muted
                                                    text-decoration-line-through">
                                                    ৳@item.OriginalPrice.ToString("N0")
                                                </span>
                                                <span class="text-danger fw-bold ms-1">
                                                    ৳@item.Price.ToString("N0")
                                                </span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted" style="font-size:13px">
                                                ৳@item.Price.ToString("N0") each
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="d-flex align-items-center justify-content-between justify-content-md-end gap-3 w-100 w-md-auto mt-2 mt-md-0 pt-2 pt-md-0 border-top border-md-top-0" style="border-color: #f1f3f5 !important;">

                                    <form asp-action="UpdateCart" asp-controller="Shop" method="post" class="d-flex align-items-center gap-2 mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <label class="d-md-none text-muted small mb-0">Qty:</label>
                                        <input type="number" name="quantity" value="@item.Quantity" min="1"
                                               style="width:65px" class="form-control form-control-sm"
                                               onchange="this.form.submit()" />
                                    </form>

                                    <div class="fw-bold text-end text-md-right" style="min-width:80px;">
                                        ৳@item.Subtotal
                                    </div>

                                    <form asp-action="RemoveFromCart" asp-controller="Shop" method="post" class="mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>

                                </div>

                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm"
                     style="border-radius:12px">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-4">Order Summary</h6>

                        <div class="d-flex justify-content-between mb-2"
                             style="font-size:14px">
                            <span class="text-muted">
                                Subtotal (@Model.Count items)
                            </span>
                            <span>৳@total.ToString("N0")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2"
                             style="font-size:13px;color:#6c757d">
                            <span>Delivery charge</span>
                            <span>Calculated at checkout</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between fw-bold mb-4">
                            <span>Subtotal</span>
                            <span style="font-size:20px">
                                ৳@total.ToString("N0")
                            </span>
                        </div>

                        <a href="/Shop/Checkout"
                           class="btn btn-primary w-100">
                            <i class="bi bi-credit-card me-2"></i>
                            Proceed to Checkout
                        </a>
                        <a href="/Home/Shop"
                           class="btn btn-outline-secondary w-100 mt-2">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart3"
               style="font-size:80px;color:#dee2e6"></i>
            <h5 class="mt-3 text-muted">Your cart is empty</h5>
            <a href="/Home/Shop" class="btn btn-primary mt-3">
                Start Shopping
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        var subtotal = @total;

        function updateTotal() {
            var select = document.getElementById('deliveryLocation');
            var deliveryCharge = parseInt(select.value) || 0;
            var grandTotal = subtotal + deliveryCharge;

            document.getElementById('deliveryCharge').textContent =
                '৳' + deliveryCharge.toLocaleString();
            document.getElementById('grandTotal').textContent =
                '৳' + grandTotal.toLocaleString();

            // Store delivery info in session via hidden inputs
            localStorage.setItem('deliveryCharge', deliveryCharge);
            localStorage.setItem('deliveryLocation',
                select.options[select.selectedIndex].text);

            // Enable checkout button only if location selected
            var btn = document.getElementById('checkoutBtn');
            if (deliveryCharge > 0) {
                btn.classList.remove('disabled');
            } else {
                btn.classList.add('disabled');
            }
        }

        // Restore selection if coming back to cart
        window.onload = function () {
            var saved = localStorage.getItem('deliveryCharge');
            if (saved) {
                var select = document.getElementById('deliveryLocation');
                for (var i = 0; i < select.options.length; i++) {
                    if (select.options[i].value == saved) {
                        select.selectedIndex = i;
                        updateTotal();
                        break;
                    }
                }
            }
        }

        // Redirect to checkout with delivery info as query params
        function goToCheckout() {
            var deliveryCharge = localStorage.getItem('deliveryCharge') || 0;
            var deliveryLocation = localStorage.getItem('deliveryLocation') || '';
            window.location = '/Shop/Checkout?deliveryCharge='
                + deliveryCharge + '&deliveryLocation='
                + encodeURIComponent(deliveryLocation);
        }
    </script>
}