<meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
@using TwentyOne.Shared.DTOs.Responses
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Track Order";

    // Change from 'as OrderResponseDto' to dynamic so both DTO types work
    dynamic order = ViewBag.Order;
    var searchedNumber = ViewBag.SearchedNumber as string;
    var myOrders = ViewBag.MyOrders as List<OrderResponseDto> ?? new List<OrderResponseDto>();

    string bgColor = "#f5f5f5";
    string statusIcon = "bi-info-circle";
    string statusMessage = "";
    int currentIdx = -1;

    if (order != null)
    {
        // Safe string conversions for property evaluations
        string currentStatus = Convert.ToString(order.Status);

        (bgColor, statusIcon, statusMessage) = currentStatus switch
        {
            "Pending" => ("#fff8e1", "bi-clock", "Waiting for confirmation"),
            "Confirmed" => ("#e3f2fd", "bi-check-circle", "Order confirmed!"),
            "Shipped" => ("#e8f5e9", "bi-truck", "On the way!"),
            "Delivered" => ("#e8f5e9", "bi-house-check", "Delivered!"),
            "Cancelled" => ("#ffebee", "bi-x-circle", "Order cancelled"),
            _ => ("#f5f5f5", "bi-info-circle", currentStatus ?? "")
        };

        var statusOrder = new[] { "Pending", "Confirmed", "Shipped", "Delivered" };
        currentIdx = Array.IndexOf(statusOrder, currentStatus);
    }
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2"></i>Track Your Package</h5>
                    <form action="/Shop/TrackOrder" method="get" class="d-flex gap-2">
                        <input type="text" name="orderNumber" value="@searchedNumber"
                               class="form-control" placeholder="Enter Order Number (e.g. TW-2026...)" required />
                        <button type="submit" class="btn btn-primary px-4">Track</button>
                    </form>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger mt-3 mb-0 py-2 small" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        </div>
                    }
                </div>
            </div>

            @if (myOrders != null && myOrders.Any())
            {
                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-list-ul me-2"></i>My Order History</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in myOrders)
                                    {
                                        <tr>
                                            <td class="fw-semibold text-primary">@o.OrderNumber</td>
                                            <td class="text-muted small">@o.CreatedAt.ToString("dd MMM yyyy")</td>
                                            <td class="fw-bold">৳@o.FinalAmount</td>
                                            <td>
                                                <span class="badge rounded-pill bg-light text-dark px-2.5 py-1.5 fs-7">
                                                    @o.Status
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/Shop/TrackOrder?orderNumber=@o.OrderNumber" class="btn btn-sm btn-outline-primary py-1 px-2">
                                                    View Details
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            @if (order != null)
            {
                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px; background:@bgColor">
                    <div class="card-body p-4 text-center">
                        <i class="bi @statusIcon text-dark fs-1 mb-2 d-block"></i>
                        <h4 class="fw-bold mb-1">Order #@order.OrderNumber</h4>
                        <p class="mb-0 text-secondary fw-semibold">@statusMessage</p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4"><i class="bi bi-truck me-2"></i>Shipment Progress</h5>

                        <div class="position-relative mb-5 mt-3 px-3">
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-primary" role="progressbar"
                                     style="width: @(order.Status == "Cancelled" ? "0%" : currentIdx == 0 ? "15%" : currentIdx == 1 ? "50%" : currentIdx == 2 ? "80%" : currentIdx == 3 ? "100%" : "0%")">
                                </div>
                            </div>

                            <div class="d-flex justify-content-between position-absolute top-50 start-0 end-0 translate-middle-y px-2">
                                <div class="text-center">
                                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center shadow-sm" style="width:28px;height:28px;font-size:12px">
                                        <i class="bi bi-clock"></i>
                                    </div>
                                    <div class="small fw-semibold mt-1 text-muted" style="font-size:11px">Pending</div>
                                </div>
                                <div class="text-center">
                                    <div class="rounded-circle @(currentIdx >= 1 ? "bg-primary text-white" : "bg-light text-muted") d-inline-flex align-items-center justify-content-center shadow-sm" style="width:28px;height:28px;font-size:12px">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                    <div class="small fw-semibold mt-1 text-muted" style="font-size:11px">Confirmed</div>
                                </div>
                                <div class="text-center">
                                    <div class="rounded-circle @(currentIdx >= 2 ? "bg-primary text-white" : "bg-light text-muted") d-inline-flex align-items-center justify-content-center shadow-sm" style="width:28px;height:28px;font-size:12px">
                                        <i class="bi bi-truck"></i>
                                    </div>
                                    <div class="small fw-semibold mt-1 text-muted" style="font-size:11px">Shipped</div>
                                </div>
                                <div class="text-center">
                                    <div class="rounded-circle @(currentIdx >= 3 ? "bg-primary text-white" : "bg-light text-muted") d-inline-flex align-items-center justify-content-center shadow-sm" style="width:28px;height:28px;font-size:12px">
                                        <i class="bi bi-house-check"></i>
                                    </div>
                                    <div class="small fw-semibold mt-1 text-muted" style="font-size:11px">Delivered</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm" style="border-radius:16px">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Order & Shipping Details</h5>
                        <div class="row g-3 small">
                            <div class="col-6 text-muted">Customer Name:</div>
                            <div class="col-6 fw-semibold text-end">@order.CustomerName</div>

                            <div class="col-6 text-muted">Phone Number:</div>
                            <div class="col-6 fw-semibold text-end">@order.CustomerPhone</div>

                            <div class="col-6 text-muted">Delivery Address:</div>
                            <div class="col-6 fw-semibold text-end text-break">@order.DeliveryAddress</div>

                            @if (!string.IsNullOrEmpty(order.Notes))
                            {
                                <div class="col-6 text-muted">Order Notes:</div>
                                <div class="col-6 fw-semibold text-end text-break text-italic">"@order.Notes"</div>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white p-4" style="border-radius:0 0 16px 16px">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span class="text-muted">Subtotal</span>
                            <span>৳@order.TotalAmount</span>
                        </div>
                        @if (order.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between mb-1 small text-success">
                                <span>Discount</span>
                                <span>- ৳@order.DiscountAmount</span>
                            </div>
                        }
                        @if (order.DeliveryCharge > 0)
                        {
                            <div class="d-flex justify-content-between mb-1 small">
                                <span class="text-muted">Delivery Charge</span>
                                <span>৳@order.DeliveryCharge</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between fw-bold pt-2 border-top mt-2">
                            <span>Final Amount</span>
                            <span style="color:#e94560; font-size:18px">৳@order.FinalAmount</span>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>