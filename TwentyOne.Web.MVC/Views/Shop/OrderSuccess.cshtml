@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Order Placed!";
    var isLoggedIn = !string.IsNullOrEmpty(
        Context.Session.GetString("JwtToken"));
    var orderNumber = ViewBag.OrderNumber as string;
}

<div class="container py-5">
    <div class="text-center py-4">
        <div style="width:90px;height:90px;background:#e8f5e9;
            border-radius:50%;display:flex;
            align-items:center;justify-content:center;
            margin:0 auto 20px">
            <i class="bi bi-check-lg"
               style="font-size:40px;color:#198754"></i>
        </div>

        <h2 class="fw-bold text-success">
            Order Placed Successfully!
        </h2>
        <p class="text-muted mt-2">
            Thank you! We'll confirm your order shortly.
        </p>

        @if (orderNumber != null)
        {
            <div class="mt-3 mb-4 p-3 d-inline-flex
                align-items-center gap-3"
                 style="background:#f8f9fa;border-radius:12px">
                <div>
                    <div class="text-muted"
                         style="font-size:11px">
                        Your Order Number
                    </div>
                    <div style="font-size:22px;font-weight:800;
                        color:#1a1a2e;letter-spacing:1px">
                        @orderNumber
                    </div>
                </div>
                <button id="copyBtn"
                        onclick="copyOrder('@orderNumber')"
                        class="btn btn-outline-secondary btn-sm"
                        title="Copy order number">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
            <p class="text-muted"
               style="font-size:12px;margin-top:-10px">
                Save this number to track your order later
            </p>
        }

        <div class="d-flex gap-3 justify-content-center
            mt-3 flex-wrap">
            @if (isLoggedIn)
            {
                <a href="/Account/MyOrders"
                   class="btn btn-primary">
                    <i class="bi bi-receipt me-2"></i>
                    My Orders
                </a>
            }
            else
            {
                <a href="/Shop/TrackOrder"
                   class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>
                    Track My Order
                </a>
            }

            @if (orderNumber != null)
            {
                <a href="/Shop/DownloadPdf?orderNumber=@orderNumber"
                   class="btn btn-outline-success"
                   target="_blank">
                    <i class="bi bi-file-pdf me-2"></i>
                    Download Receipt
                </a>
            }

            <a href="/Home/Shop"
               class="btn btn-outline-secondary">
                <i class="bi bi-shop me-2"></i>
                Continue Shopping
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyOrder(number) {
            navigator.clipboard.writeText(number);
            var btn = document.getElementById('copyBtn');
            btn.innerHTML =
                '<i class="bi bi-check text-success"></i>';
            btn.classList.add('btn-success');
            btn.classList.remove('btn-outline-secondary');
            setTimeout(() => {
                btn.innerHTML =
                    '<i class="bi bi-clipboard"></i>';
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-secondary');
            }, 2000);
        }
    </script>
}