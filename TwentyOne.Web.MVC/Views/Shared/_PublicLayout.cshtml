            <div class="footer-bottom text-center">
                <p class="mb-0">© 2026 TwentyOne Diecast Store. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>

        function togglePassword(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Mobile Menu

        function toggleMobileMenu() {
        var card = document.getElementById('mobileMenuCard');
        card.style.display =
        card.style.display === 'none' ? 'block' : 'none';
        }

        // Track Order Card

        function toggleTrackCard() {
        var card = document.getElementById('trackOrderCard');
        if (!card) return;
        card.style.display =
        card.style.display === 'none' ? 'block' : 'none';
        if (card.style.display === 'block') {
        setTimeout(() => {
        var inp = document.getElementById('trackInput');
        if (inp) inp.focus();
        }, 50);
        }
        }

        function goTrack() {
        var val = (document.getElementById('trackInput')?.value || '')
        .trim();
        if (!val) return;
        if (val.startsWith('PO-')) {
        @if (isLoggedIn)
        {
            <text>
                window.location = '/Account/PreOrderDetail?number=' + val;
            </text>
        }
        else
        {
            <text>
                document.getElementById('trackCardMsg').innerHTML =
                '<div class="alert alert-warning mb-0 py-2" ' +
                  'style="font-size:12px;border-radius:8px">' +
                '<i class="bi bi-lock me-1"></i>' +
                'You need to login to see your pre-ordered item.' +
                '</div>';
            </text>
        }
        return;
        }
        window.location = '/Shop/TrackOrder?orderNumber=' + val;
        }

        function goMobileTrack() {
        var val = (document.getElementById('mobileTrackInput')?.value || '')
        .trim();
        if (!val) return;
        if (val.startsWith('PO-')) {
        alert('You need to login to see your pre-ordered item.');
        return;
        }
        window.location = '/Shop/TrackOrder?orderNumber=' + val;
        }

        // Close on outside click

        document.addEventListener('click', function (e) {
        // Track order card
        var trackNav = document.getElementById('trackOrderNav');
        var trackCard = document.getElementById('trackOrderCard');
        if (trackNav && trackCard &&
        !trackNav.contains(e.target) &&
        trackCard.style.display === 'block') {
        trackCard.style.display = 'none';
        }

        // Mobile menu card
        var mobileCard = document.getElementById('mobileMenuCard');
        var hamburger = document.getElementById('hamburgerBtn');
        if (mobileCard && hamburger &&
        !mobileCard.contains(e.target) &&
        !hamburger.contains(e.target) &&
        mobileCard.style.display === 'block') {
        mobileCard.style.display = 'none';
        }
        });

        // Shop Sidebar

        function openSidebar() {
        document.getElementById('brandSidebar')?.classList.add('open');
        var overlay = document.getElementById('sidebarOverlay');
        if (overlay) overlay.style.display = 'block';
        }

        function closeSidebar() {
        document.getElementById('brandSidebar')?.classList.remove('open');
        var overlay = document.getElementById('sidebarOverlay');
        if (overlay) overlay.style.display = 'none';
        }

        // Filter Modal

        function openFilter() {
        document.getElementById('filterOverlay').style.display = 'block';
        document.getElementById('filterCard').style.display = 'block';
        document.body.style.overflow = 'hidden';
        }

        function closeFilter() {
        document.getElementById('filterOverlay').style.display = 'none';
        document.getElementById('filterCard').style.display = 'none';
        document.body.style.overflow = '';
        }

        function selectSort(val) {
        document.getElementById('sortByInput').value = val;
        document.querySelectorAll('[onclick^="selectSort"]').forEach(c => {
        c.classList.toggle('filter-chip-active',
        c.getAttribute('onclick') === `selectSort('${val}')`);
        });
        }

        function toggleScale(val) {
        var input = document.getElementById('scaleInput');
        var isActive = input.value === val;
        input.value = isActive ? '' : val;
        document.querySelectorAll('[onclick^="toggleScale"]').forEach(c => {
        c.classList.toggle('filter-chip-active',
        !isActive &&
        c.getAttribute('onclick') === `toggleScale('${val}')`);
        });
        }

        var selectedTypes = {
        limited: false, preorder: false, instock: false
        };

        function toggleType(type) {
        selectedTypes[type] = !selectedTypes[type];
        document.getElementById('isLimitedInput').value =
        selectedTypes.limited ? 'true' : '';
        document.getElementById('isPreOrderInput').value =
        selectedTypes.preorder ? 'true' : '';
        document.getElementById('inStockInput').value =
        selectedTypes.instock ? 'true' : '';
        var el = document.querySelector(`[onclick="toggleType('${type}')"]`);
        if (el) el.classList.toggle('filter-chip-active',
        selectedTypes[type]);
        }

        // Cart Bubble System

        var toastTimer;

        function showCartBubble(count, total) {
        var bubble = document.getElementById('cartBubble');
        var bubbleCount = document.getElementById('bubbleCount');
        var bubbleTotal = document.getElementById('bubbleTotal');
        var inner = document.getElementById('cartBubbleInner');

        bubble.style.display = 'block';
        bubbleCount.textContent = count;
        bubbleTotal.textContent = '৳' + total.toLocaleString();

        // Bounce animation
        inner.style.transform = 'scale(1.15)';
        inner.style.boxShadow =
        '0 12px 35px rgba(233,69,96,0.6)';
        setTimeout(() => {
        inner.style.transform = 'scale(1)';
        inner.style.boxShadow =
        '0 8px 25px rgba(233,69,96,0.4)';
        }, 300);
        }

        function showToast(productName) {
        var toast = document.getElementById('cartToast');
        var name = document.getElementById('toastProductName');

        name.textContent = productName || 'Product';
        toast.style.display = 'block';

        // Slide in animation
        toast.style.transform = 'translateX(120%)';
        toast.style.transition = 'transform 0.3s ease';
        setTimeout(() => {
        toast.style.transform = 'translateX(0)';
        }, 10);

        // Auto hide after 3 seconds
        clearTimeout(toastTimer);
        toastTimer = setTimeout(hideToast, 3000);
        }

        function hideToast() {
        var toast = document.getElementById('cartToast');
        toast.style.transform = 'translateX(120%)';
        setTimeout(() => {
        toast.style.display = 'none';
        }, 300);
        }
        async function restoreCartBubble() {
        try {
        var response = await fetch('/Shop/GetCartSummary');
        var data = await response.json();

        if (data.count > 0) {
        showCartBubble(data.count, data.total);
        }
        } catch (e) {
        // silently fail
        }
        }

        // Run on every page load
        document.addEventListener('DOMContentLoaded',
        restoreCartBubble);

        // Intercept all
        // add-to-cart forms

        document.addEventListener('submit', async function (e) {
        var form = e.target;

        // Check if this is an add-to-cart form
        if (!form.querySelector('[name="productId"]') ||
        !form.action?.includes('AddToCart'))
        return;

        e.preventDefault();

        var formData = new FormData(form);
        var productName = form.closest('.product-card')
        ?.querySelector('.product-name')?.textContent?.trim()
        || 'Product';

        try {
        var response = await fetch(form.action, {
        method: 'POST',
        headers: {
        'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData
        });

        var data = await response.json();

        if (data.success) {
        // Show toast
        showToast(productName);

        // Show/update bubble
        showCartBubble(data.cartCount, data.cartTotal);

        // Update navbar cart count
        var cartBadge = document.querySelector('.cart-badge');
        if (cartBadge) {
        cartBadge.textContent = data.cartCount;
        } else {
        // Create badge if it doesn't exist
        var cartLink = document.querySelector(
        'a[href="/Shop/Cart"]');
        if (cartLink) {
        var badge = document.createElement('span');
        badge.className = 'cart-badge';
        badge.textContent = data.cartCount;
        cartLink.appendChild(badge);
        }
        }
        }
        } catch (err) {
        // Fallback to normal form submit
        form.submit();
        }
        });

        // Show bubble on page load if cart has items
        @{
            var sessionCartJson = Context.Session.GetString("Cart");
            if (!string.IsNullOrEmpty(sessionCartJson))
            {
                <text>
                    // Cart has items - show bubble
                    setTimeout(function () {
                    // We'll update this via API on page load
                    }, 500);
                </text>
            }
        }

    </script>
    
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Floating Cart Bubble -->
    <div id="cartBubble"
         style="display:none;position:fixed;bottom:24px;right:24px;
        z-index:9999;cursor:pointer"
         onclick="window.location='/Shop/Cart'">
        <div style="background:#e94560;color:white;
            border-radius:50px;padding:12px 20px;
            display:flex;align-items:center;gap:10px;
            box-shadow:0 8px 25px rgba(233,69,96,0.4);
            transition:all 0.3s;font-weight:600"
             id="cartBubbleInner">
            <div style="position:relative">
                <i class="bi bi-cart3"
                   style="font-size:22px"></i>
                <span id="bubbleCount"
                      style="position:absolute;top:-8px;right:-8px;
                    background:white;color:#e94560;
                    border-radius:50%;width:18px;height:18px;
                    font-size:10px;font-weight:700;
                    display:flex;align-items:center;
                    justify-content:center">
                    0
                </span>
            </div>
            <div>
                <div style="font-size:11px;opacity:0.85">
                    Cart Total
                </div>
                <div id="bubbleTotal"
                     style="font-size:16px;font-weight:800">
                    ৳0
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="cartToast"
         style="display:none;position:fixed;top:80px;right:20px;
        z-index:9999;min-width:280px;max-width:320px">
        <div style="background:white;border-radius:16px;
            padding:16px;
            box-shadow:0 8px 30px rgba(0,0,0,0.15);
            border-left:4px solid #e94560;
            display:flex;align-items:center;gap:12px">
            <div style="width:40px;height:40px;background:#fff0f3;
                border-radius:10px;display:flex;
                align-items:center;justify-content:center;
                flex-shrink:0">
                <i class="bi bi-cart-check"
                   style="color:#e94560;font-size:18px"></i>
            </div>
            <div style="flex:1">
                <div style="font-weight:700;color:#1a1a2e;
                    font-size:14px">
                    Added to Cart!
                </div>
                <div id="toastProductName"
                     style="font-size:12px;color:#6c757d;
                margin-top:2px"></div>
            </div>
            <button onclick="hideToast()"
                    style="background:none;border:none;
                color:#aaa;font-size:20px;
                cursor:pointer;line-height:1;
                padding:0 4px">
                ×
            </button>
        </div>
    </div>

</body>
</html>