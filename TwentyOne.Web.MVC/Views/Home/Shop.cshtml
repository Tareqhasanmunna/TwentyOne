@model TwentyOne.Shared.DTOs.Responses.PagedResponseDto<TwentyOne.Shared.DTOs.Responses.ProductResponseDto>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Shop";
    var filter = ViewBag.Filter as
        TwentyOne.Shared.DTOs.Requests.ProductFilterDto;
    var brands = ViewBag.Brands as
        List<TwentyOne.Shared.DTOs.Responses.BrandResponseDto>;
}

<div class="shop-layout">

    <!-- BRAND SIDEBAR -->

    <aside class="brand-sidebar" id="brandSidebar">
        <div class="brand-sidebar-inner">
            <div class="sidebar-header">
                <h6 class="fw-bold mb-0">Brands</h6>
                <!-- Close button mobile only -->
                <button class="d-md-none"
                        onclick="closeSidebar()"
                        style="background:none;border:none;
                               font-size:22px;cursor:pointer;
                               color:#6c757d;line-height:1">×</button>
            </div>

            <div class="brand-list">
                <a href="/Home/Shop"
                   class="brand-item @(filter?.BrandId == null
                       ? "brand-item-active" : "")">
                    <i class="bi bi-grid-3x3-gap me-2"></i>
                    All Brands
                    <span class="brand-count">
                        @(Model?.TotalCount ?? 0)
                    </span>
                </a>

                @foreach (var brand in brands ??
                    new List<TwentyOne.Shared.DTOs.Responses.BrandResponseDto>())
                {
                    <a href="/Home/Shop?brandId=@brand.Id"
                       class="brand-item @(filter?.BrandId == brand.Id
                           ? "brand-item-active" : "")">
                        <i class="bi bi-tag me-2"></i>
                        @brand.Name
                        <span class="brand-count">
                            @brand.ProductCount
                        </span>
                    </a>
                }
            </div>
        </div>
    </aside>

    <!-- Sidebar overlay mobile -->
    <div id="sidebarOverlay"
         onclick="closeSidebar()"
         style="display:none;position:fixed;top:0;left:0;
                right:0;bottom:0;background:rgba(0,0,0,0.5);
                z-index:199;backdrop-filter:blur(2px)"></div>

    <!-- MAIN CONTENT -->
    <main class="shop-main">

        <!-- Search & Controls Bar -->
        <div class="shop-controls">

            <!-- Mobile: Brands button -->
            <button class="d-md-none btn btn-outline-secondary btn-sm"
                    onclick="openSidebar()"
                    style="border-radius:20px;white-space:nowrap">
                <i class="bi bi-tag me-1"></i>Brands
            </button>

            <!-- Search Bar -->
            <div class="shop-search-wrap">
                <form method="get" action="/Home/Shop"
                      id="shopSearchForm">
                    <!-- Keep existing filters when searching -->
                    @if (filter?.BrandId.HasValue == true)
                    {
                        <input type="hidden" name="brandId"
                               value="@filter.BrandId" />
                    }
                    @if (filter?.IsLimitedEdition == true)
                    {
                        <input type="hidden" name="isLimitedEdition"
                               value="true" />
                    }
                    @if (filter?.IsPreOrder == true)
                    {
                        <input type="hidden" name="isPreOrder"
                               value="true" />
                    }

                    <div class="shop-search-inner">
                        <i class="bi bi-search shop-search-icon"></i>
                        <input type="text" name="search"
                               id="shopSearchInput"
                               value="@filter?.Search"
                               placeholder="Search products..."
                               class="shop-search-input"
                               autocomplete="off" />
                        @if (!string.IsNullOrEmpty(filter?.Search))
                        {
                            <a href="/Home/Shop"
                               class="shop-search-clear">×</a>
                        }
                        <button type="submit"
                                class="shop-search-btn">
                            Search
                        </button>
                    </div>
                </form>
            </div>

            <!-- Filter Button -->
            <button onclick="openFilter()"
                    class="btn btn-outline-secondary btn-sm"
                    style="border-radius:20px;white-space:nowrap;
                           flex-shrink:0">
                <i class="bi bi-sliders me-1"></i>
                Filter
                @{
                    var activeFilters = 0;
                    if (filter?.IsLimitedEdition == true)
                        activeFilters++;
                    if (filter?.IsPreOrder == true) activeFilters++;
                    if (filter?.MinPrice.HasValue == true) activeFilters++;
                    if (filter?.MaxPrice.HasValue == true) activeFilters++;
                    if (!string.IsNullOrEmpty(filter?.Scale))
                        activeFilters++;
                }
                @if (activeFilters > 0)
                {
                    <span class="badge ms-1"
                          style="background:#e94560;font-size:10px">
                        @activeFilters
                    </span>
                }
            </button>

            <!-- Results count -->
            <span class="text-muted d-none d-md-block"
                  style="font-size:13px;white-space:nowrap;
                         flex-shrink:0">
                @(Model?.TotalCount ?? 0) products
            </span>
        </div>

        <!-- Active filter tags -->
        @{
            var hasActiveFilters =
                !string.IsNullOrEmpty(filter?.Search) ||
                filter?.BrandId.HasValue == true ||
                filter?.IsLimitedEdition == true ||
                filter?.IsPreOrder == true ||
                !string.IsNullOrEmpty(filter?.Scale) ||
                filter?.MinPrice.HasValue == true ||
                filter?.MaxPrice.HasValue == true;
        }

        @if (hasActiveFilters)
        {
            <div class="active-filters">
                @if (!string.IsNullOrEmpty(filter?.Search))
                {
                    <span class="active-tag">
                        "@filter.Search"
                        <a href="/Home/Shop?@(filter.BrandId.HasValue
                            ? "brandId="+filter.BrandId : "")">×</a>
                    </span>
                }
                @if (filter?.BrandId.HasValue == true)
                {
                    var bn = brands?.FirstOrDefault(
                        b => b.Id == filter.BrandId)?.Name;
                    <span class="active-tag">
                        @bn
                        <a href="/Home/Shop?@(!string.IsNullOrEmpty(
                            filter.Search) ? "search="+filter.Search : "")">
                            ×
                        </a>
                    </span>
                }
                @if (filter?.IsLimitedEdition == true)
                {
                    <span class="active-tag">
                        Limited Edition
                        <a href="/Home/Shop">×</a>
                    </span>
                }
                @if (filter?.IsPreOrder == true)
                {
                    <span class="active-tag">
                        Pre-Order
                        <a href="/Home/Shop">×</a>
                    </span>
                }
                @if (!string.IsNullOrEmpty(filter?.Scale))
                {
                    <span class="active-tag">
                        Scale @filter.Scale
                        <a href="/Home/Shop">×</a>
                    </span>
                }
                <a href="/Home/Shop"
                   style="font-size:12px;color:#e94560;
                          text-decoration:none">
                    Clear all
                </a>
            </div>
        }

        <!-- Products Grid -->
        @if (Model != null && Model.Items.Any())
        {
            <div class="products-grid">
                @foreach (var product in Model.Items)
                {
                    
                        await Html.RenderPartialAsync("_ProductCard",
                            (TwentyOne.Shared.DTOs.Responses
                                .ProductResponseDto)product);
                    
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5">
                    <div class="d-flex align-items-center
                        justify-content-center gap-3">

                        <!-- Previous -->
                        @if (Model.HasPreviousPage)
                        {
                            <a href="/Home/Shop?page=@(Model.Page - 1)
                                @(!string.IsNullOrEmpty(filter?.Search)
                                   ? "&search=" + filter.Search : "")
                                @(filter?.BrandId.HasValue == true
                                   ? "&brandId=" + filter.BrandId : "")
                                @(filter?.IsLimitedEdition == true
                                   ? "&isLimitedEdition=true" : "")
                                @(filter?.IsPreOrder == true
                                   ? "&isPreOrder=true" : "")"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-chevron-left me-1"></i>
                                Previous
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary"
                                    disabled>
                                <i class="bi bi-chevron-left me-1"></i>
                                Previous
                            </button>
                        }

                        <!-- Page counter -->
                        <div class="d-flex align-items-center gap-2">
                            @{
                                int startPage = Math.Max(1, Model.Page - 2);
                                int endPage = Math.Min(
                                    Model.TotalPages, Model.Page + 2);
                            }

                            @if (startPage > 1)
                            {
                                <a href="/Home/Shop?page=1"
                                   class="btn btn-sm btn-outline-secondary"
                                   style="border-radius:8px;
                                min-width:36px">1</a>
                                @if (startPage > 2)
                                {
                                    <span class="text-muted">...</span>
                                }
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                @if (i == Model.Page)
                                {
                                    <button class="btn btn-sm btn-primary"
                                            style="border-radius:8px;
                                        min-width:36px"
                                            disabled>
                                        @i
                                    </button>
                                }
                                else
                                {
                                    <a href="/Home/Shop?page=@i
                                        @(!string.IsNullOrEmpty(filter?.Search)
                                           ? "&search=" + filter.Search : "")
                                        @(filter?.BrandId.HasValue == true
                                           ? "&brandId=" + filter.BrandId : "")
                                        @(filter?.IsLimitedEdition == true
                                           ? "&isLimitedEdition=true" : "")
                                        @(filter?.IsPreOrder == true
                                           ? "&isPreOrder=true" : "")"
                                       class="btn btn-sm btn-outline-secondary"
                                       style="border-radius:8px;
                                        min-width:36px">
                                        @i
                                    </a>
                                }
                            }

                            @if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <span class="text-muted">...</span>
                                }
                                <a href="/Home/Shop?page=@Model.TotalPages"
                                   class="btn btn-sm btn-outline-secondary"
                                   style="border-radius:8px;min-width:36px">
                                    @Model.TotalPages
                                </a>
                            }
                        </div>

                        <!-- Page info -->
                        <div style="font-size:13px;color:#6c757d;
                            white-space:nowrap">
                            Page @Model.Page of @Model.TotalPages
                        </div>

                        <!-- Next -->
                        @if (Model.HasNextPage)
                        {
                            <a href="/Home/Shop?page=@(Model.Page + 1)
                                @(!string.IsNullOrEmpty(filter?.Search)
                                   ? "&search=" + filter.Search : "")
                                @(filter?.BrandId.HasValue == true
                                   ? "&brandId=" + filter.BrandId : "")
                                @(filter?.IsLimitedEdition == true
                                   ? "&isLimitedEdition=true" : "")
                                @(filter?.IsPreOrder == true
                                   ? "&isPreOrder=true" : "")"
                               class="btn btn-outline-secondary">
                                Next
                                <i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary"
                                    disabled>
                                Next
                                <i class="bi bi-chevron-right ms-1"></i>
                            </button>
                        }
                    </div>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-search"
                   style="font-size:60px;color:#dee2e6"></i>
                <h5 class="mt-3 text-muted">No products found</h5>
                <a href="/Home/Shop" class="btn btn-primary mt-2">
                    Clear Filters
                </a>
            </div>
        }
    </main>
</div>

<!-- Filter Modal -->
<div id="filterOverlay"
     style="display:none;position:fixed;top:0;left:0;
            right:0;bottom:0;z-index:1050;
            backdrop-filter:blur(4px);
            background:rgba(0,0,0,0.4)"
     onclick="closeFilter()"></div>

<div id="filterCard"
     style="display:none;position:fixed;top:50%;left:50%;
            transform:translate(-50%,-50%);z-index:1060;
            background:white;border-radius:20px;padding:28px;
            width:90%;max-width:500px;max-height:85vh;
            overflow-y:auto;
            box-shadow:0 20px 60px rgba(0,0,0,0.2)">

    <div class="d-flex justify-content-between
                align-items-center mb-4">
        <h5 class="fw-bold mb-0">
            <i class="bi bi-sliders me-2"></i>Filter
        </h5>
        <button onclick="closeFilter()"
                style="background:none;border:none;font-size:24px;
                       cursor:pointer;color:#6c757d;line-height:1">
            ×
        </button>
    </div>

    <form id="filterForm" method="get" action="/Home/Shop">
        @if (filter?.BrandId.HasValue == true)
        {
            <input type="hidden" name="brandId"
                   value="@filter.BrandId" />
        }
        @if (!string.IsNullOrEmpty(filter?.Search))
        {
            <input type="hidden" name="search"
                   value="@filter.Search" />
        }

        <!-- Sort -->
        <div class="mb-4">
            <div class="filter-label">Sort By</div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var (val, lbl) in new[]
                {
                    ("newest","Newest"),
                    ("price_asc","Price ↑"),
                    ("price_desc","Price ↓"),
                    ("name","A-Z")
                })
                {
                    <button type="button"
                            class="filter-chip
                                @(filter?.SortBy == val
                                    ? "filter-chip-active" : "")"
                            onclick="selectSort('@val')">
                        @lbl
                    </button>
                }
                <input type="hidden" name="sortBy"
                       id="sortByInput"
                       value="@(filter?.SortBy ?? "newest")" />
            </div>
        </div>

        <!-- Scale -->
        <div class="mb-4">
            <div class="filter-label">Scale</div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var scale in new[]
                {
                    "1:18","1:24","1:43","1:64","1:72","1:87"
                })
                {
                    <button type="button"
                            class="filter-chip
                                @(filter?.Scale == scale
                                    ? "filter-chip-active" : "")"
                            onclick="toggleScale('@scale')">
                        @scale
                    </button>
                }
                <input type="hidden" name="scale"
                       id="scaleInput"
                       value="@filter?.Scale" />
            </div>
        </div>

        <!-- Price -->
        <div class="mb-4">
            <div class="filter-label">Price Range (৳)</div>
            <div class="d-flex gap-2 align-items-center">
                <input type="number" name="minPrice"
                       class="form-control form-control-sm"
                       placeholder="Min"
                       value="@filter?.MinPrice"
                       style="border-radius:10px" />
                <span style="color:#6c757d">—</span>
                <input type="number" name="maxPrice"
                       class="form-control form-control-sm"
                       placeholder="Max"
                       value="@filter?.MaxPrice"
                       style="border-radius:10px" />
            </div>
        </div>

        <!-- Type -->
        <div class="mb-4">
            <div class="filter-label">Product Type</div>
            <div class="d-flex gap-2 flex-wrap">
                <button type="button"
                        class="filter-chip
                            @(filter?.IsLimitedEdition == true
                                ? "filter-chip-active" : "")"
                        onclick="toggleType('limited')">
                    Limited Edition
                </button>
                <button type="button"
                        class="filter-chip
                            @(filter?.IsPreOrder == true
                                ? "filter-chip-active" : "")"
                        onclick="toggleType('preorder')">
                    Pre-Order
                </button>
                <button type="button"
                        class="filter-chip
                            @(filter?.InStockOnly == true
                                ? "filter-chip-active" : "")"
                        onclick="toggleType('instock')">
                    In Stock Only
                </button>
                <input type="hidden" name="isLimitedEdition"
                       id="isLimitedInput" value="" />
                <input type="hidden" name="isPreOrder"
                       id="isPreOrderInput" value="" />
                <input type="hidden" name="inStockOnly"
                       id="inStockInput" value="" />
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit"
                    class="btn btn-primary flex-grow-1">
                <i class="bi bi-check-lg me-1"></i>Apply
            </button>
            <a href="/Home/Shop"
               class="btn btn-outline-secondary">
                Clear All
            </a>
        </div>
    </form>
</div>